# ============================================================
# .env.example — Superholic Lab environment variable template
# Copy to .env and fill in real values (never commit .env)
# ============================================================

# ── Supabase ──────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Stripe ────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_ALL_SUBJECTS_PRICE_ID=price_...
STRIPE_FAMILY_PRICE_ID=price_...
STRIPE_ALL_SUBJECTS_ANNUAL_PRICE_ID=price_...
STRIPE_FAMILY_ANNUAL_PRICE_ID=price_...

# ── AI providers ──────────────────────────────────────────────
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...
ANTHROPIC_API_KEY=sk-ant-...

# ── AI provider routing — override defaults per task ──────────
# Defaults are defined in lib/api/handlers.js AI_ROUTING object.
# Set these in Vercel to swap providers without a code deploy.

AI_CHAT_PROVIDER=openai
AI_CHAT_MODEL=gpt-4o-mini

AI_SUMMARIZE_PROVIDER=openai
AI_SUMMARIZE_MODEL=gpt-4o-mini

AI_GRADE_PROVIDER=openai
AI_GRADE_MODEL=gpt-4o-mini

AI_QUESTION_PROVIDER=openai
AI_QUESTION_MODEL=o4-mini

AI_EXAM_PROVIDER=openai
AI_EXAM_MODEL=gpt-4o-mini

AI_QUEST_PROVIDER=openai
AI_QUEST_MODEL=gpt-4o-mini

AI_BULK_PROVIDER=anthropic
AI_BULK_MODEL=claude-3-5-sonnet-20241022

# ── Wena RAP feature flag — Sprint 3 onwards ──────────────────
# When 'true', English chats with curriculum coordinates use Retrieval-Augmented
# Pedagogy templates assembled from the playbook cell at (level, topic, sub_topic).
# When 'false' (default), the legacy OMNI_TUTOR_SYSTEM_PROMPT is used unchanged.
WENA_RAP_ENABLED=false

# ── Wena RAP canary rollout — Sprint 4 ────────────────────────
# Optional 0-100 integer. When set, RAP fires for ~N% of students (deterministic
# hash of student_id mod 100). Overridden to ON when WENA_RAP_ENABLED=true.
# Recommended rollout: 10 → soak 48h → 100. Leave unset in dev unless testing.
WENA_RAP_ROLLOUT_PCT=

# ── App ───────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://www.superholiclab.com
