{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/api/chat",               "destination": "/api/index" },
    { "source": "/api/checkout",           "destination": "/api/index" },
    { "source": "/api/webhook",            "destination": "/api/index" },
    { "source": "/api/portal",             "destination": "/api/index" },
    { "source": "/api/admin",              "destination": "/api/index" },
    { "source": "/api/admin-edit",         "destination": "/api/index" },
    { "source": "/api/analytics",          "destination": "/api/index" },
    { "source": "/api/pause",              "destination": "/api/index" },
    { "source": "/api/referral",           "destination": "/api/index" },
    { "source": "/api/account-delete",     "destination": "/api/index" },
    { "source": "/api/export",             "destination": "/api/index" },
    { "source": "/api/contact",            "destination": "/api/index" },
    { "source": "/api/qa-questions",       "destination": "/api/index" },
    { "source": "/api/generate",           "destination": "/api/index" },
    { "source": "/api/generate-question",  "destination": "/api/index" },
    { "source": "/api/generate-exam",      "destination": "/api/index" },
    { "source": "/api/grade-answer",       "destination": "/api/index" },
    { "source": "/api/save-exam-result",   "destination": "/api/index" },
    { "source": "/api/generate-quest",     "destination": "/api/index" },
    { "source": "/api/analyze-weakness",   "destination": "/api/index" },
    { "source": "/api/summarize-chat",     "destination": "/api/index" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",         "value": "SAMEORIGIN" },
        { "key": "X-XSS-Protection",        "value": "1; mode=block" },
        { "key": "Referrer-Policy",         "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",      "value": "camera=(), microphone=(), geolocation=()" }
    ]
    }
  ],
  "crons": [
    {
      "path": "/api/cron/auto-fill-bank",
      "schedule": "0 2 * * 0" 
    }
  ]
}